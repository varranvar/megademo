{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "bug-triage": {
      "type": "local",
      "enabled": true,
      "command": ["./run-tool.sh", "bug-triage"]
    },
    "cve-audit": {
      "type": "local",
      "enabled": true,
      "command": ["./run-tool.sh", "cve-audit"]
    },
    "ubuntu-archive": {
      "type": "local",
      "enabled": true,
      "command": ["bash", "-c", "cd mcp/ubuntu-archive && . .venv/bin/activate && exec python3 server.py"]
    }
  }
}
