#!/usr/bin/env bash
set -euo pipefail

usage() {
    echo "Usage: $0 <changes-or-deb-file> [severity]"
    echo "  changes-or-deb-file - Path to .changes or .deb file"
    echo "  severity            - Minimum severity: error, warning, info, pedantic (default: warning)"
    exit 1
}

if [ $# -lt 1 ]; then
    usage
fi

FILE="$1"
SEVERITY="${2:-warning}"

SEVERITY_MAP="error:E warning:W info:I pedantic:P"
MIN_FLAG=""
case "${SEVERITY}" in
    error) MIN_FLAG="-E" ;;
    warning) MIN_FLAG="" ;;
    info) MIN_FLAG="-I" ;;
    pedantic) MIN_FLAG="--pedantic" ;;
esac

if ! command -v lintian &>/dev/null; then
    echo "ERROR: lintian is not installed."
    echo "Install with: sudo apt install lintian"
    echo "Then run: lintian --output-format=json ${MIN_FLAG} ${FILE}"
    exit 1
fi

echo "Running lintian on ${FILE} (min severity: ${SEVERITY})..."
lintian --output-format=json ${MIN_FLAG} "${FILE}"
